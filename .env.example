# Telegram Bot
BOT_TOKEN=your_bot_token_here

# MySQL Database
DB_HOST=your_mysql_host_here
DB_PORT=3306
DB_NAME=railway
DB_USER=root
DB_PASSWORD=your_db_password_here

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here

